# Cloudflare Account ID
    CLOUDFLARE_ACCOUNT_ID="YOUR_CLOUDFLARE_ACCOUNT_ID"

    # AI Model Bindings
    AI_MODEL_TRANSLATE="@cf/meta/m2m100-1.2b"
    AI_MODEL_SUMMARIZE="@cf/facebook/bart-large-cnn"
    AI_MODEL_SENTIMENT="@cf/distilbert-base-uncased-finetuned-sst-2-english"
    AI_MODEL_SEARCH="@cf/baai/bge-base-en-v1.5"
    AI_MODEL_GENERATE_CONTENT="@cf/meta/llama-2-7b-chat-int8"
    AI_MODEL_PROCESS_DATA="@cf/baai/bge-base-en-v1.5"

    # JWT Secret (replace with a strong, randomly generated secret in production)
    JWT_SECRET="YOUR_JWT_SECRET"
